{
    "name": "gupalo/monolog-dbal-logger",
    "description": "Monolog Handler for DBAL",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "ext-json": "*",
        "ext-mbstring": "*",
        "doctrine/dbal": "^4.4",
        "monolog/monolog": "^3.10",
        "symfony/console": "^7.4|^8.0",
        "symfony/event-dispatcher": "^7.4|^8.0",
        "symfony/http-kernel": "^7.4|^8.0"
    },
    "require-dev": {
        "doctrine/orm": "^3.6",
        "easycorp/easyadmin-bundle": "^4.27",
        "gupalo/symfony-form-transformers": "^1.3",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Gupalo\\MonologDbalLogger\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gupalo\\MonologDbalLogger\\Tests\\": "tests/"
        }
    }
}
